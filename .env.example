# Main site
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.example.mongodb.net/mydb
SESSION_SECRET=change_me

# Admin API key used by admin-site to call main site's admin endpoints
ADMIN_API_KEY=replace-with-strong-random-key

# Admin site credentials (only used by admin-site)
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# Admin site config
MAIN_SITE_BASE=http://localhost:3000
